import torch
import torch.nn.functional as F
import numpy as np
import torch.optim as optim
import torch.nn as nn
import torch.distributions as distributions
import matplotlib.pyplot as plt

import gymnasium as gym

# env

train_env = gym.make("CartPole-v1")
test_env = gym.make("CartPole-v1")


# Model
class MLP(nn.Module):
    def __init__(self, input_dim, hidden_dim, output_dim, dropout=0.01):
        super().__init__()
        self.fc1 = nn.Linear(input_dim, hidden_dim)
        self.fc2 = nn.Linear(hidden_dim, output_dim)
        self.dropout = nn.Dropout(p=dropout)

    def forward(self, x):
        x = self.fc1(x)
        x = self.dropout(x)
        x = F.relu(x)
        x = self.fc2(x)
        return x


class ActorCritic(nn.Module):
    def __init__(self, actor, critic):
        super().__init__()
        self.actor = actor
        self.critic = critic

    def forward(self, state):
        action_pred = self.actor(state)
        value_pred = self.critic(state)
        return action_pred, value_pred


# seed
SEED = 42
torch.manual_seed(SEED)


# Setup model

INPUT_DIM = train_env.observation_space.shape[0]
HIDDEN_DIM = 512
OUTPUT_DIM = train_env.action_space.n
DROUPOUT = 0.01

actor = MLP(INPUT_DIM, HIDDEN_DIM, OUTPUT_DIM, DROUPOUT)
critic = MLP(INPUT_DIM, HIDDEN_DIM, 1, DROUPOUT)

policy = ActorCritic(actor, critic)
device = torch.device("cpu")


def train_one_episode(env, policy, optimizer, discounted_factor, device):
    policy.train()

    done = False
    truncated = False
    log_probs_action = []
    values = []
    rewards = []
    episode_reward = 0

    state, _ = env.reset()

    while not done and not truncated:
        state = torch.tensor(state, dtype=torch.float32).unsqueeze(0).to(device)
        action_pred, value_pred = policy(state)

        action_prob = F.softmax(action_pred, dim=-1)
        dis = distributions.Categorical(action_prob)
        action = dis.sample()

        state, reward, done, truncated, _ = env.step(action.item())
        log_prob_action = dis.log_prob(action)
        log_probs_action.append(log_prob_action)
        values.append(value_pred)
        rewards.append(reward)

        episode_reward += reward

    log_probs_action = torch.cat(
        log_probs_action
    )  # probs_action là list các tensor nhỏ nhưng chưa gộp thành 1 tensor lớn
    values = torch.cat(values).squeeze(-1)
    # print(values.shape)
    returns = calculated_reward(rewards, discounted_factor)
    policy_loss, value_loss = policy_update(
        returns, log_probs_action, values, optimizer
    )

    return policy_loss, value_loss, episode_reward


def calculated_reward(rewards, discounted_factor):
    returns = []
    R = 0
    for reward in reversed(rewards):
        R = reward + R * discounted_factor
        returns.insert(0, R)
    returns = torch.tensor(returns)

    return (returns - returns.mean()) / returns.std()


def policy_update(returns, log_probs_action, values, optimizer):
    returns = returns.detach()  # rewards không phụ thuộc và theta để đưa ra xác xuất .

    policy_loss = -(returns * log_probs_action).sum()

    value_loss = F.smooth_l1_loss(returns, values).sum()

    optimizer.zero_grad()
    loss = policy_loss + value_loss
    loss.backward()
    optimizer.step()
    return policy_loss, value_loss


def evaluate(env, policy, device):
    episode_reward = 0
    done = False
    truncated = False

    policy.eval()
    state, _ = env.reset()

    while not done and not truncated:
        state = torch.tensor(state, dtype=torch.float32).unsqueeze(0).to(device)

        action_pred, _ = policy(state)

        action_prob = F.softmax(action_pred, dim=-1)
        action = torch.argmax(action_prob, dim=-1)
        state, reward, done, truncated, _ = env.step(action.item())

        episode_reward += reward
    return episode_reward


# Config

if __name__ == "__main__":
    import argparse

    parser = argparse.ArgumentParser()
    parser.add_argument("--actor_lr", type=float, default=1e-3)
    parser.add_argument("--critic_lr", type=float, default=1e-3)
    parser.add_argument("--num_episodes", type=int, default=250)
    parser.add_argument("--gamma", type=float, default=0.99)

    args = parser.parse_args()

    actor_lr = args.actor_lr
    critic_lr = args.critic_lr
    DISCOUNT_FACTOR = args.gamma
    NUM_EPISODES = args.num_episodes
    PRINT_EVERY = 10
    REWARD_THRESHOLD = 457
    N_TRIALS = 30
    train_rewards = []
    test_rewards = []
    optimizer = optim.Adam(
        [
            {"params": actor.parameters(), "lr": actor_lr},
            {"params": critic.parameters(), "lr": critic_lr},
        ]
    )
    for episode in range(1, NUM_EPISODES + 1):

        policy_loss, critic_loss, train_reward = train_one_episode(
            train_env, policy, optimizer, DISCOUNT_FACTOR, device
        )

        test_reward = evaluate(test_env, policy, device)

        train_rewards.append(train_reward)
        test_rewards.append(test_reward)

        mean_train_rewards = np.mean(train_rewards[-N_TRIALS:])
        mean_test_rewards = np.mean(test_rewards[-N_TRIALS:])

        if episode % PRINT_EVERY == 0:

            print(
                f"| Episode: {episode:3} | Mean Train Rewards: {mean_train_rewards:5.1f} | Mean Test Rewards: {mean_test_rewards:5.1f} |"
            )

        if mean_test_rewards >= REWARD_THRESHOLD:

            print(f"Reached reward threshold in {episode} episodes")

            break
